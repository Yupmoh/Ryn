[*.cs]
generated_code = true

# These files are produced by ClangSharpPInvokeGenerator from the saucer C ABI headers
# (vendor/saucer-bindings, saucer MIT). They are mechanical derivative works of those headers,
# so they carry the attribution header at the top of every file.
#
# The header is applied AT GENERATION TIME by ClangSharp's `--headerFile build/clangsharp/header.txt`
# option (wired into build/clangsharp/ryn-bindings.rsp), so a regeneration reproduces it. Note that
# `dotnet format` does NOT stamp these files: `generated_code = true` makes the IDE0073 analyzer skip
# them, so the file_header_template below documents the canonical header text and keeps it discoverable
# but cannot itself add or fix the header. Keep header.txt and file_header_template in sync.
#
# The canonical, full third-party license text lives in /THIRD-PARTY-NOTICES.md at the repository
# root, which is packed into the NuGet packages.

# Disable all analyzers and style rules on generated code...
dotnet_analyzer_diagnostic.severity = none

# ...except the file-header rule, kept enabled to document the canonical saucer/MIT attribution text.
# Severity is `suggestion`, NOT `warning`: the project builds with TreatWarningsAsErrors +
# EnforceCodeStyleInBuild, and IDE0073 cannot fix generated files, so a warning would be unfixable
# build noise. file_header_template uses literal `\n` for newlines per the .editorconfig spec, and
# must stay in sync with build/clangsharp/header.txt (the file ClangSharp actually prepends).
dotnet_diagnostic.IDE0073.severity = suggestion
file_header_template = Bindings generated by ClangSharp from the saucer C ABI headers.\nsaucer is Copyright (c) 2023 Saucer and licensed under the MIT License.\nThese files are a derivative work of those headers; see THIRD-PARTY-NOTICES.md\nat the repository root for the full license text. Ryn itself is MIT-licensed.
