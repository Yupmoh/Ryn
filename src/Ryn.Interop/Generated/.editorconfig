[*.cs]
generated_code = true

# These files are produced by ClangSharpPInvokeGenerator from the saucer C ABI headers
# (vendor/saucer-bindings, saucer MIT). They are mechanical derivative works of those headers,
# so they carry the attribution header below. The header text is enforced by IDE0073
# (dotnet_diagnostic.IDE0073) and stamped onto every file by `dotnet format`.
#
# Regenerating the bindings (build/regenerate-bindings.sh) runs `rm -rf` over this folder and
# rewrites the files WITHOUT the header — ClangSharp emits no file header. After regenerating,
# run `dotnet format style src/Ryn.Interop/Ryn.Interop.csproj --diagnostics IDE0073` to re-stamp
# the header (or add `--headerFile build/clangsharp/header.txt` to the ClangSharp .rsp). Until
# that step runs, the header is missing; this rule makes the omission a fixable analyzer hit
# rather than a silent loss. The canonical, full third-party license text lives in
# /THIRD-PARTY-NOTICES.md at the repository root, which is packed into the NuGet packages.

# Disable all analyzers and style rules on generated code...
dotnet_analyzer_diagnostic.severity = none

# ...except the file-header rule, so the saucer/MIT attribution is wired and `dotnet format` can
# stamp it. Severity is `suggestion`, NOT `warning`: the project builds with
# TreatWarningsAsErrors + EnforceCodeStyleInBuild, and the freshly regenerated files have no
# header yet, so a warning would break the build before `dotnet format` runs. file_header_template
# uses literal `\n` for newlines per the .editorconfig spec.
dotnet_diagnostic.IDE0073.severity = suggestion
file_header_template = Bindings generated by ClangSharp from the saucer C ABI headers.\nsaucer is Copyright (c) 2023 Saucer and licensed under the MIT License.\nThese files are a derivative work of those headers; see THIRD-PARTY-NOTICES.md\nat the repository root for the full license text. Ryn itself is MIT-licensed.
